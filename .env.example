# Copy to .env and adjust. docker compose fails explicitly if MCP_TOKEN is missing.

# Shared secret for the MCP endpoint. Clients must send
# "Authorization: Bearer <MCP_TOKEN>". Generate with: openssl rand -hex 32
MCP_TOKEN=change-me

# Source subnet allowed by the gateway (nginx allow/deny).
ALLOWED_SUBNET=192.168.1.0/24

# Host interface to publish ports on. Use the host's LAN IP on multi-homed
# machines so nothing listens on other interfaces; 0.0.0.0 on single-NIC hosts.
BIND_IP=0.0.0.0

# Client-reachable base URL for downloading generated artifacts over HTTP
# (ComfyUI's /view endpoint, served by the gateway on port 8188). The MCP server
# advertises this in its `instructions` so remote clients know where to fetch
# results. Set it to the host's LAN address (NOT 0.0.0.0) — the same host as the
# MCP endpoint, on port 8188.
COMFYUI_PUBLIC_URL=http://192.168.1.2:8188

# Same as COMFYUI_PUBLIC_URL but for the comfyui-gpu1 instance (the second
# GPU's ComfyUI, served by the gateway on port 8189). Lets the two instances
# handle generations in parallel, one per GPU.
COMFYUI_PUBLIC_URL_GPU1=http://192.168.1.2:8189

# docker compose reads this automatically, so plain `docker compose up -d`
# starts the GPU1 pair too (no need to pass --profile gpu1 every time).
# Comment this out on single-GPU hosts.
COMPOSE_PROFILES=gpu1

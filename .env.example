# Copy to .env and adjust. docker compose fails explicitly if MCP_TOKEN is missing.

# Shared secret for the MCP endpoint. Clients must send
# "Authorization: Bearer <MCP_TOKEN>". Generate with: openssl rand -hex 32
MCP_TOKEN=change-me

# Source subnet allowed by the gateway (nginx allow/deny).
ALLOWED_SUBNET=192.168.1.0/24

# Host interface to publish ports on. Use the host's LAN IP on multi-homed
# machines so nothing listens on other interfaces; 0.0.0.0 on single-NIC hosts.
BIND_IP=0.0.0.0
